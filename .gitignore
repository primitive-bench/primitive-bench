# Python
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
dist/
build/

# uv / turbo
uv.lock.bak
.turbo/
node_modules/

# Node / Next (apps/mcp)
.next/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Run outputs (per-run result dirs are local; ingested into DuckDB, not committed)
runs/
*.duckdb
*.duckdb.wal

# HELD-OUT DATA MUST NEVER BE COMMITTED HERE.
golden-sets-heldout/
*.heldout.jsonl
*.hmac.key

# Reranker: the full dev split is generated locally from MTEB reranking sets
# (SciDocs / AskUbuntu) and is NOT redistributed — only dev.example.jsonl is committed.
golden-sets-public/reranker/dev.jsonl

# Chunking: the full dev split + corpora are generated locally from the Chroma
# chunking_evaluation set and are NOT redistributed — only the self-authored
# dev.example.jsonl + corpora/example_*.md are committed.
golden-sets-public/chunking/dev.jsonl
golden-sets-public/chunking/corpora/*.md
!golden-sets-public/chunking/corpora/example_*.md

# Secrets / env
.env
.env.*

# OS / editor
.DS_Store
.idea/
.vscode/
